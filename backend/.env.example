# =========================================================
# NoteTube AI — Backend Environment Configuration Template
# =========================================================
# Copy this file to ".env" in the same directory and fill in
# real values. Never commit your actual ".env" file to version
# control — it should be listed in .gitignore.

# ---- Google Gemini API ------------------------------------
# Required. Obtain a key from Google AI Studio:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for note generation.
GEMINI_MODEL=gemini-2.5-flash

# ---- Flask Configuration -----------------------------------
# One of: development | production
FLASK_ENV=development

# Enables Flask debug mode (verbose errors, auto-reload).
# Set to False in production.
FLASK_DEBUG=True

# Host/port the Flask dev server binds to.
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ---- CORS ----------------------------------------------------
# Comma-separated list of allowed origins for the frontend.
# Example for local dev + a deployed Vercel frontend:
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-frontend.vercel.app

# ---- File Storage --------------------------------------------
# Directory (relative to backend/) where generated DOCX/PDF
# files are temporarily stored before download.
TEMP_FILE_DIR=temp_files

# Max age (in seconds) before generated files are purged.
FILE_CLEANUP_MAX_AGE_SECONDS=3600

# ---- Transcript Extraction -------------------------------------
# Optional: preferred transcript languages, in priority order.
TRANSCRIPT_LANGUAGE_PRIORITY=en,en-US,en-GB

# ---- Misc / Security -------------------------------------------
# Max transcript length (characters) accepted before chunking.
MAX_TRANSCRIPT_CHARS=100000

# Secret key used for any session/signing needs (generate a random string).
SECRET_KEY=change_this_to_a_long_random_string
